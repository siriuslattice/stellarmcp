{
  "name": "stellar-mcp-x402",
  "version": "0.1.0",
  "description": "MCP server giving AI agents access to Stellar blockchain data — accounts, DEX, transactions, assets — with x402 micropayments settled on Stellar",
  "type": "module",
  "bin": {
    "stellarmcp": "dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node dist/index.js",
    "inspect": "pnpm build && npx @modelcontextprotocol/inspector dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo": "tsx examples/agent-demo.ts",
    "demo:service": "tsx examples/mock-external-service.ts",
    "keygen": "tsx scripts/keygen.ts",
    "x402:client": "tsx scripts/x402-client.ts",
    "setup:usdc": "tsx scripts/setup-usdc.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@x402/core": "^2.9.0",
    "@x402/express": "^2.9.0",
    "@x402/stellar": "^2.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@stellar/stellar-sdk": "^15.0.1",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.5.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "MIT",
  "keywords": [
    "stellar",
    "mcp",
    "x402",
    "blockchain",
    "ai-agents",
    "micropayments"
  ]
}
