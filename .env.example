# Stellar network
STELLAR_NETWORK=testnet
HORIZON_URL=https://horizon-testnet.stellar.org

# Transport: "stdio" for MCP clients, "http" for x402-monetized REST access
TRANSPORT=stdio

# x402 (required when TRANSPORT=http)
STELLAR_PAYEE_ADDRESS=G...your_stellar_address...
OZ_FACILITATOR_URL=https://channels.openzeppelin.com/x402/testnet
OZ_API_KEY=your_openzeppelin_api_key

# Server (HTTP mode)
PORT=4021
HOST=0.0.0.0

# Logging
LOG_LEVEL=info
